<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.practice.mapa.ui.common.ZoomableImageView
            android:id="@+id/detail_image"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:scaleType="centerInside"
            android:contentDescription="detail_image" />

        <TextView
            android:id="@+id/detail_text_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textAppearance="?attr/textAppearanceHeadlineSmall" />

        <TextView
            android:id="@+id/detail_text_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="?attr/colorSecondary" />

        <!-- Discount badge (GONE when no discount) -->
        <TextView
            android:id="@+id/detail_text_discount_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_discount_badge"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:contentDescription="detail_text_discount_badge"
            android:visibility="gone" />

        <!-- Original price strikethrough (GONE when no discount) -->
        <TextView
            android:id="@+id/detail_text_price_original"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:contentDescription="detail_text_price_original"
            android:visibility="gone" />

        <!-- Current / discounted price -->
        <TextView
            android:id="@+id/detail_text_price_current"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold"
            android:contentDescription="detail_text_price_current" />

        <!-- "You save $X.XX" (GONE when no discount) -->
        <TextView
            android:id="@+id/detail_text_savings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="@color/color_savings_green"
            android:textStyle="bold"
            android:contentDescription="detail_text_savings"
            android:visibility="gone" />

        <TextView
            android:id="@+id/detail_text_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/detail_button_add_to_cart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:contentDescription="detail_button_add_to_cart"
            android:text="@string/catalog_add_to_cart" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
