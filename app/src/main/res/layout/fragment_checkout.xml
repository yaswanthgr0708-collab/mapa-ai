<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Step indicator -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/checkout_step1"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="1"
                android:contentDescription="checkout_step_1"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:background="@drawable/bg_step_indicator" />

            <View
                android:layout_width="40dp"
                android:layout_height="2dp"
                android:background="?attr/colorOutline" />

            <TextView
                android:id="@+id/checkout_step2"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="2"
                android:contentDescription="checkout_step_2"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:background="@drawable/bg_step_indicator" />

            <View
                android:layout_width="40dp"
                android:layout_height="2dp"
                android:background="?attr/colorOutline" />

            <TextView
                android:id="@+id/checkout_step3"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="3"
                android:contentDescription="checkout_step_3"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:background="@drawable/bg_step_indicator" />

        </LinearLayout>

        <!-- Address section -->
        <LinearLayout
            android:id="@+id/checkout_section_address"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/checkout_layout_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/checkout_hint_name">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/checkout_input_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionNext"
                    android:inputType="textPersonName" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/checkout_layout_street"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/checkout_hint_street">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/checkout_input_street"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionNext"
                    android:inputType="textPostalAddress" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/checkout_layout_city"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/checkout_hint_city">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/checkout_input_city"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionNext"
                    android:inputType="textCapWords" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/checkout_layout_zip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/checkout_hint_zip">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/checkout_input_zip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionDone"
                    android:inputType="number" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/checkout_label_country"
                android:textAppearance="?attr/textAppearanceLabelMedium" />

            <Spinner
                android:id="@+id/checkout_spinner_country"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:contentDescription="checkout_spinner_country" />

        </LinearLayout>

        <!-- Payment section -->
        <LinearLayout
            android:id="@+id/checkout_section_payment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/checkout_layout_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/checkout_hint_card">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/checkout_input_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:maxLength="16" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/checkout_layout_expiry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/checkout_hint_expiry">
                <!--
                  inputType="phone" gives a numeric keypad on all devices AND allows
                  the TextWatcher to insert the '/' separator programmatically.
                  inputType="number" uses an InputFilter that strips non-digit characters
                  before the TextWatcher sees them, which would break auto-formatting.
                -->
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/checkout_input_expiry"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:contentDescription="checkout_input_expiry"
                    android:inputType="phone"
                    android:maxLength="5" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/checkout_layout_cvv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/checkout_hint_cvv">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/checkout_input_cvv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:contentDescription="checkout_input_cvv"
                    android:inputType="numberPassword"
                    android:maxLength="3" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- Review section -->
        <LinearLayout
            android:id="@+id/checkout_section_review"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/checkout_label_ship_to"
                android:textAppearance="?attr/textAppearanceLabelLarge" />

            <TextView
                android:id="@+id/checkout_text_address_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:contentDescription="checkout_text_address_summary"
                android:textAppearance="?attr/textAppearanceBodyMedium" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/checkout_label_payment"
                android:textAppearance="?attr/textAppearanceLabelLarge" />

            <TextView
                android:id="@+id/checkout_text_payment_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:contentDescription="checkout_text_payment_summary"
                android:textAppearance="?attr/textAppearanceBodyMedium" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/checkout_label_order_total"
                android:textAppearance="?attr/textAppearanceLabelLarge" />

            <TextView
                android:id="@+id/checkout_text_order_total"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:contentDescription="checkout_text_order_total"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="?attr/colorPrimary" />

            <!-- You saved $X.XX — GONE when cart has no discounts -->
            <TextView
                android:id="@+id/checkout_review_total_savings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:contentDescription="checkout_review_total_savings"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="@color/color_savings_green"
                android:textStyle="bold"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Navigation buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/checkout_button_back"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:contentDescription="checkout_button_back"
                android:text="@string/checkout_back"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/checkout_button_next"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:contentDescription="checkout_button_next"
                android:text="@string/checkout_next" />

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
