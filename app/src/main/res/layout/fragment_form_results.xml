<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/results_label_text"
            android:textAppearance="?attr/textAppearanceLabelMedium" />
        <TextView
            android:id="@+id/results_text_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="results_text_text"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/results_label_number"
            android:textAppearance="?attr/textAppearanceLabelMedium" />
        <TextView
            android:id="@+id/results_text_number"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="results_text_number"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/results_label_email"
            android:textAppearance="?attr/textAppearanceLabelMedium" />
        <TextView
            android:id="@+id/results_text_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="results_text_email"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/results_label_password"
            android:textAppearance="?attr/textAppearanceLabelMedium" />
        <TextView
            android:id="@+id/results_text_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="results_text_password"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/results_label_multiline"
            android:textAppearance="?attr/textAppearanceLabelMedium" />
        <TextView
            android:id="@+id/results_text_multiline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="results_text_multiline"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/results_label_date"
            android:textAppearance="?attr/textAppearanceLabelMedium" />
        <TextView
            android:id="@+id/results_text_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="results_text_date"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/results_label_time"
            android:textAppearance="?attr/textAppearanceLabelMedium" />
        <TextView
            android:id="@+id/results_text_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="results_text_time"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/results_label_country"
            android:textAppearance="?attr/textAppearanceLabelMedium" />
        <TextView
            android:id="@+id/results_text_country"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="results_text_country"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/results_label_radio"
            android:textAppearance="?attr/textAppearanceLabelMedium" />
        <TextView
            android:id="@+id/results_text_radio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="results_text_radio"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/results_label_checkboxes"
            android:textAppearance="?attr/textAppearanceLabelMedium" />
        <TextView
            android:id="@+id/results_text_checkboxes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="results_text_checkboxes"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/results_label_switch1"
            android:textAppearance="?attr/textAppearanceLabelMedium" />
        <TextView
            android:id="@+id/results_text_switch1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="results_text_switch1"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/results_label_switch2"
            android:textAppearance="?attr/textAppearanceLabelMedium" />
        <TextView
            android:id="@+id/results_text_switch2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="results_text_switch2"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/results_label_switch3"
            android:textAppearance="?attr/textAppearanceLabelMedium" />
        <TextView
            android:id="@+id/results_text_switch3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="results_text_switch3"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/results_label_seekbar"
            android:textAppearance="?attr/textAppearanceLabelMedium" />
        <TextView
            android:id="@+id/results_text_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:contentDescription="results_text_seekbar"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
