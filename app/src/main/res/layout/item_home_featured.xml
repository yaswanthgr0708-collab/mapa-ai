<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="120dp"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="8dp">

        <!-- Icon with optional discount badge overlay -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="80dp">

            <ImageView
                android:id="@+id/featured_item_icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="" />

            <TextView
                android:id="@+id/featured_item_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:background="@drawable/bg_discount_badge"
                android:paddingHorizontal="2dp"
                android:paddingVertical="1dp"
                android:textColor="#FFFFFF"
                android:textSize="7sp"
                android:textStyle="bold"
                android:visibility="gone" />

        </FrameLayout>

        <TextView
            android:id="@+id/featured_item_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:textSize="11sp"
            android:textAlignment="center" />

        <!-- Original price (strikethrough, GONE when no discount) -->
        <TextView
            android:id="@+id/featured_item_price_original"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="9sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textAlignment="center"
            android:visibility="gone" />

        <!-- Current / discounted price -->
        <TextView
            android:id="@+id/featured_item_price_current"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textAlignment="center" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
