<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <!-- ── Auth screens ──────────────────────────────────────────────────── -->

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.practice.mapa.ui.auth.LoginFragment"
        android:label="@string/label_login">

        <action
            android:id="@+id/action_loginFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />

        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />

        <action
            android:id="@+id/action_loginFragment_to_forgotPasswordDialog"
            app:destination="@id/forgotPasswordDialog" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.practice.mapa.ui.auth.RegisterFragment"
        android:label="@string/label_register" />

    <dialog
        android:id="@+id/forgotPasswordDialog"
        android:name="com.practice.mapa.ui.auth.ForgotPasswordDialog"
        android:label="@string/forgot_title" />

    <!-- ── Main shell (bottom-nav destinations) ──────────────────────────── -->

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.practice.mapa.ui.home.HomeFragment"
        android:label="@string/tab_home">

        <action
            android:id="@+id/action_homeFragment_to_catalogFragment"
            app:destination="@id/catalogFragment" />

        <action
            android:id="@+id/action_homeFragment_to_productDetailFragment"
            app:destination="@id/productDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/catalogFragment"
        android:name="com.practice.mapa.ui.catalog.CatalogFragment"
        android:label="@string/tab_catalog">

        <argument
            android:name="categoryFilter"
            app:argType="string"
            android:defaultValue="" />

        <action
            android:id="@+id/action_catalogFragment_to_productDetailFragment"
            app:destination="@id/productDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/productDetailFragment"
        android:name="com.practice.mapa.ui.catalog.ProductDetailFragment"
        android:label="@string/label_product_detail">

        <argument
            android:name="productId"
            app:argType="integer"
            android:defaultValue="0" />

        <deepLink
            android:id="@+id/deepLink_product"
            app:uri="mapa://product/{productId}" />
    </fragment>

    <fragment
        android:id="@+id/cartFragment"
        android:name="com.practice.mapa.ui.cart.CartFragment"
        android:label="@string/label_cart">

        <action
            android:id="@+id/action_cartFragment_to_checkoutFragment"
            app:destination="@id/checkoutFragment" />
    </fragment>

    <fragment
        android:id="@+id/checkoutFragment"
        android:name="com.practice.mapa.ui.cart.CheckoutFragment"
        android:label="@string/label_checkout">

        <argument
            android:name="orderTotal"
            app:argType="float"
            android:defaultValue="0" />

        <action
            android:id="@+id/action_checkoutFragment_to_orderConfirmationFragment"
            app:destination="@id/orderConfirmationFragment"
            app:popUpTo="@id/cartFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/orderConfirmationFragment"
        android:name="com.practice.mapa.ui.cart.OrderConfirmationFragment"
        android:label="@string/label_order_confirmation">

        <argument
            android:name="orderId"
            app:argType="string"
            android:defaultValue="ORD-000000" />

        <argument
            android:name="orderTotal"
            app:argType="float"
            android:defaultValue="0" />
    </fragment>

    <fragment
        android:id="@+id/formsFragment"
        android:name="com.practice.mapa.ui.forms.FormsFragment"
        android:label="@string/tab_forms">
        <action
            android:id="@+id/action_formsFragment_to_formResultsFragment"
            app:destination="@id/formResultsFragment" />
    </fragment>

    <fragment
        android:id="@+id/formResultsFragment"
        android:name="com.practice.mapa.ui.forms.FormResultsFragment"
        android:label="@string/label_form_results">
        <argument android:name="resultText" app:argType="string" android:defaultValue="" />
        <argument android:name="resultNumber" app:argType="string" android:defaultValue="" />
        <argument android:name="resultEmail" app:argType="string" android:defaultValue="" />
        <argument android:name="resultPassword" app:argType="string" android:defaultValue="" />
        <argument android:name="resultMultiline" app:argType="string" android:defaultValue="" />
        <argument android:name="resultDate" app:argType="string" android:defaultValue="" />
        <argument android:name="resultTime" app:argType="string" android:defaultValue="" />
        <argument android:name="resultCountry" app:argType="string" android:defaultValue="" />
        <argument android:name="resultRadio" app:argType="string" android:defaultValue="" />
        <argument android:name="resultCheckboxes" app:argType="string" android:defaultValue="" />
        <argument android:name="resultSwitch1" app:argType="boolean" android:defaultValue="false" />
        <argument android:name="resultSwitch2" app:argType="boolean" android:defaultValue="false" />
        <argument android:name="resultSwitch3" app:argType="boolean" android:defaultValue="false" />
        <argument android:name="resultSeekbar" app:argType="integer" android:defaultValue="0" />
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.practice.mapa.ui.settings.SettingsFragment"
        android:label="@string/tab_settings" />

    <fragment
        android:id="@+id/gesturesFragment"
        android:name="com.practice.mapa.ui.gestures.GesturesFragment"
        android:label="@string/label_gestures" />

    <fragment
        android:id="@+id/alertsFragment"
        android:name="com.practice.mapa.ui.alerts.AlertsFragment"
        android:label="@string/label_alerts" />

    <fragment
        android:id="@+id/webViewFragment"
        android:name="com.practice.mapa.ui.web.WebViewFragment"
        android:label="@string/label_web" />

    <fragment
        android:id="@+id/systemFragment"
        android:name="com.practice.mapa.ui.system.SystemFragment"
        android:label="@string/label_system" />
</navigation>
